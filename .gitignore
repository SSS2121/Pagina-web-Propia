# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Node (in case you use it later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Portfolio Assets (Images and Certificates)
# We want these to be tracked so they appear on the website
!/assets/certificates/*.jpg
!/assets/certificates/*.JPG
!/assets/certificates/*.png
!/assets/certificates/*.webp
!/assets/certificates/COLOCA_AQUI_LOS_CERTIFICADOS.txt

!/assets/images/*.jpg
!/assets/images/*.JPG
!/assets/images/*.png
!/assets/images/COLOCA_AQUI_TU_FOTO.txt

